# ── ブラウザ（ポータル）用：公開前提。保護は RLS が担う ──────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── ローカルのワーカー（Claude Code / tools/*.mjs）専用 ──────────────
# service_role は全権キー。絶対に NEXT_PUBLIC を付けず、ブラウザにも Vercel にも置かない。
# これはこの PC のローカル .env.local だけに置く（.gitignore 済み）。
SUPABASE_SERVICE_ROLE_KEY=
# 自分のログイン用メール（user_id 解決に使う）
JOBHUNT_USER_EMAIL=
# 基本プロフィール台帳のパス（既定値でよければ空でも可）
PROFILE_PATH=C:\Users\haru8\Downloads\profile-daicho.md

# ※ Anthropic API キーは使いません。AI 処理は Claude Code（サブスク）が tools/playbooks に従って行います。
